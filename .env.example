# ── Meta Marketing API ───────────────────────────────────────
# Get from: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_ID=your_ad_account_id_here   # just the number, not "act_"
META_ADSET_ID=your_adset_id_here
META_PAGE_ID=your_page_id_here

# ── Gemini API (copy generation) ─────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram (morning brief) ──────────────────────────────────
# 1. Create bot via @BotFather → get token
# 2. Get your chat_id via https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Slack (morning brief — alternative to Telegram) ──────────
# Create incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
