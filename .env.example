# ── OpenClaw Gateway ─────────────────────────────────────────
# Generate a token: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_TZ=UTC

# ── Gemini API (LLM + web search + copy generation) ────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Telegram ────────────────────────────────────────────────
# 1. Create bot via @BotFather → get token
# 2. Get your chat_id via https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Meta Marketing API ──────────────────────────────────────
# Get from: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_access_token_here
META_AD_ACCOUNT_ID=your_ad_account_id_here
META_ADSET_ID=your_adset_id_here
META_PAGE_ID=your_page_id_here

# ── Composio (Google Ads via MCP) ────────────────────────────
# MCP URL from Composio dashboard (includes user_id in query string)
COMPOSIO_MCP_URL=https://backend.composio.dev/v3/mcp/YOUR_SERVER_ID/mcp?user_id=YOUR_USER_ID
COMPOSIO_MCP_API_KEY=your_composio_api_key_here

# ── PostHog (Google Ads data warehouse) ────────────────────
# Get from: PostHog Project Settings → Personal API Keys
POSTHOG_API_KEY=phx_your_posthog_api_key_here
POSTHOG_HOST=https://app.posthog.com
POSTHOG_PROJECT_ID=your_project_id_here

# ── Docker image (override to use local build) ──────────────
# OPENCLAW_IMAGE=openclaw:local
